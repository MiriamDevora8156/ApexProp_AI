{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/app",
    "rootDir": "src",             // אומר ל-TS שהבסיס הוא תיקיית src
    "types": [
      "node"
    ]
  },
  "files": [
    "src/main.ts",
    "src/server.ts"               // הוספנו את זה כי הוא נמצא בתוך src עכשיו
  ],
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/**/*.spec.ts"
  ]
}